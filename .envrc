#!/bin/bash

# Circuit-break re-entry. If a submodule's .envrc calls source_up_if_exists,
# direnv walks up to this file again — without a guard the load recurses
# until the stack overflows. We track a colon-separated stack of .envrc
# directories visited during this evaluation; bail if we've already entered
# this one. The variable is non-exported, so it's scoped to the direnv
# evaluation subshell and reset on every reload.
case ":${_PS_ENVRC_STACK:-}:" in
    *":$PWD:"*) return 0 ;;
esac
_PS_ENVRC_STACK="${_PS_ENVRC_STACK:+$_PS_ENVRC_STACK:}$PWD"

_load_subdir_envrcs() {
    # Convention: any direct subfolder containing an .envrc is opted in. This
    # avoids coupling to git (e.g. .gitmodules) so it works identically in dev
    # and customer modes — directories excluded from the bundle via .zipignore
    # (such as scripts-general-util) are naturally skipped because they don't
    # exist customer-side. find(1) is used instead of a `*/` glob so this is
    # robust under zsh's default NOMATCH and POSIX shells; hidden dirs like
    # .git and .envrc.d are filtered out explicitly.
    local sub
    while IFS= read -r sub; do
        sub="${sub#./}"
        [ -n "$sub" ] || continue
        if [ -f "$sub/.envrc" ]; then
            source_env "$PWD/$sub"
        fi
    done < <(find . -mindepth 1 -maxdepth 1 -type d ! -name '.*' 2>/dev/null)
}

_checksum() {
    local file="$1"
    [ -f "$file" ] || return 0
    for cmd in sha256sum sha1sum md5sum; do
        local algo="${cmd%sum}"
        if command -v "$cmd" &>/dev/null; then
            printf '%s: %s\n' "$algo" "$("$cmd" "$file")"
        elif command -v shasum &>/dev/null && [[ "$cmd" == sha256sum ]]; then
            printf '%s: %s\n' "$algo" "$(shasum -a 256 "$file")"
        elif command -v shasum &>/dev/null && [[ "$cmd" == sha1sum ]]; then
            printf '%s: %s\n' "$algo" "$(shasum -a 1 "$file")"
        elif command -v md5 &>/dev/null && [[ "$cmd" == md5sum ]]; then
            printf '%s: %s\n' "$algo" "$(md5 "$file")"
        fi
    done
}

_build_zip() {
    [ -d "bin" ] || return 0
    echo "--- bin/output.zip (before) ---"
    _checksum bin/output.zip
    rm -f bin/output.zip
    echo "--- bin/output.zip (archive) ---"
    zip -r "bin/output.zip" . -x@.zipignore
    echo "--- bin/output.zip (after) ---"
    _checksum bin/output.zip
}

_show_bundle_upload_guidance() {
    command -v ps_bundle_upload &>/dev/null || return 0

    local bundle_branch
    bundle_branch="$(ps_bundle_upload --print-branch 2>/dev/null)" || return 0

    cat <<help
--- bundle upload ---
Dirty changes were packaged in bin/output.zip.
Default dirty branch: ${bundle_branch}
Upload after JFrog CLI is configured:
    ps_bundle_upload
help
}

if [ "${1:-}" = "-live" ]; then
    # Customer env: put the bundled helpers on PATH, restore +x, and source
    # any opted-in subfolder .envrcs that survived bundling.
    # `jf rt u --explode` strips the Unix file mode server-side, so files
    # arrive as 0644 even though the source zip carries 0755. Re-apply on
    # activation; idempotent if already executable.
    #
    # Subfolder .envrcs that survived bundling commonly use direnv stdlib
    # helpers (source_env, PATH_add, expand_path, ...). The customer's shell
    # has no direnv; supply minimal polyfills so those .envrcs Just Work.
    # Each guard only fires if direnv (or someone else) hasn't already
    # defined the function, so dev mode is untouched.
    if ! command -v PATH_add >/dev/null 2>&1; then
        PATH_add() { export PATH="$1:$PATH"; }
    fi
    if ! command -v expand_path >/dev/null 2>&1; then
        expand_path() {
            local _p="${1:-.}"
            if [ -d "$_p" ]; then
                ( cd "$_p" && pwd )
            else
                ( cd "$(dirname "$_p")" && printf '%s/%s\n' "$(pwd)" "$(basename "$_p")" )
            fi
        }
    fi
    if ! command -v source_env >/dev/null 2>&1; then
        source_env() {
            local _rcpath="$1"
            [ -d "$_rcpath" ] && _rcpath="$_rcpath/.envrc"
            [ -f "$_rcpath" ] || return 0
            local _prev="$PWD"
            cd "$(dirname "$_rcpath")" || return 1
            # shellcheck source=/dev/null
            . "./$(basename "$_rcpath")"
            local _ec=$?
            cd "$_prev" || return $_ec
            return $_ec
        }
    fi
    # source_up_if_exists / watch_file are direnv-only conveniences with no
    # meaningful customer-side equivalent; no-op them so they never error.
    if ! command -v source_up_if_exists >/dev/null 2>&1; then
        source_up_if_exists() { :; }
    fi
    if ! command -v watch_file >/dev/null 2>&1; then
        watch_file() { :; }
    fi

    export PATH="$PWD/.envrc.d:$PATH"
    if [ -d "$PWD/.envrc.d" ]; then
        find "$PWD/.envrc.d" -type f -exec chmod +x {} +
    fi
    _load_subdir_envrcs
else
    # Developer env: register helpers via direnv, load any opted-in subfolder
    # .envrcs, rebuild the bundle, and surface upload guidance for dirty work.
    source_up_if_exists
    PATH_add .envrc.d
    _load_subdir_envrcs
    _build_zip
    _show_bundle_upload_guidance
fi
